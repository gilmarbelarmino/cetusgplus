<script>
(function() {
    // --- LГ“GICA DO ANIVERSГҒRIO ---
    const bdKey = 'birthday_modal_shown_' + new Date().toISOString().slice(0, 10);
    const birthdayPeople = <?= json_encode($birthdayPeople) ?>;
    const currentUserId = '<?= $user['id'] ?>';
    
    if (birthdayPeople.length > 0 && !sessionStorage.getItem(bdKey)) {
        let currentSlide = 0;

        window.renderSlide = function(index) {
            const person = birthdayPeople[index];
            const isMe = person.id === currentUserId;
            const avatarHtml = person.avatar_url 
                ? `<img src="${person.avatar_url}" style="width: 100%; height: 100%; object-fit: cover;">` 
                : `<div style="width: 100%; height: 100%; background: linear-gradient(135deg, #5B21B6, #EC4899); display: flex; align-items: center; justify-content: center; color: white; font-weight: 900; font-size: 2.5rem;">${person.name.substring(0, 2).toUpperCase()}</div>`;

            let html = isMe ? `
                <div style="font-size: 3.5rem; margin-bottom: 1rem; animation: bdFloat 2s ease-in-out infinite;">рҹҺӮ</div>
                <div style="width: 120px; height: 120px; border-radius: 50%; overflow: hidden; margin: 0 auto 1.5rem; border: 4px solid #EC4899; box-shadow: 0 8px 25px rgba(236, 72, 153, 0.3);">${avatarHtml}</div>
                <h2 style="font-size: 1.75rem; font-weight: 900; background: linear-gradient(135deg, #EC4899, #8B5CF6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.75rem;">Feliz AniversГЎrio, ${person.name.split(' ')[0]}! рҹҺү</h2>
                <p style="color: #64748b; font-size: 1rem; line-height: 1.6; max-width: 380px; margin: 0 auto;">Que este novo ano de vida seja repleto de realizaГ§Гөes, saГәde e muitas alegrias! рҹҘівңЁ</p>
            ` : `
                <div style="font-size: 3.5rem; margin-bottom: 1rem; animation: bdFloat 2s ease-in-out infinite;">рҹҺҲ</div>
                <div style="width: 120px; height: 120px; border-radius: 50%; overflow: hidden; margin: 0 auto 1.5rem; border: 4px solid #F59E0B; box-shadow: 0 8px 25px rgba(245, 158, 11, 0.3);">${avatarHtml}</div>
                <h2 style="font-size: 1.5rem; font-weight: 900; color: #0F172A; margin-bottom: 0.75rem;">рҹҺӮ Hoje Г© aniversГЎrio do(a) amigo(a)!</h2>
                <p style="font-size: 1.35rem; font-weight: 900; background: linear-gradient(135deg, #F59E0B, #EF4444); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem;">${person.name}</p>
                <p style="color: #64748b; font-size: 0.95rem; line-height: 1.6;">NГЈo esqueГ§a de dar os parabГ©ns! рҹҘірҹҺү</p>
            `;

            document.getElementById('bdSlideContainer').innerHTML = html;
            const counter = document.getElementById('bdSlideCounter');
            if (counter) counter.textContent = `${index + 1} / ${birthdayPeople.length}`;
        };

        window.nextBdSlide = () => { currentSlide = (currentSlide + 1) % birthdayPeople.length; renderSlide(currentSlide); };
        window.prevBdSlide = () => { currentSlide = (currentSlide - 1 + birthdayPeople.length) % birthdayPeople.length; renderSlide(currentSlide); };
        window.closeBirthdayModal = () => { document.getElementById('birthdayModal').style.display = 'none'; sessionStorage.setItem(bdKey, '1'); };

        setTimeout(() => {
            renderSlide(0);
            document.getElementById('birthdayModal').style.display = 'flex';
            // Criar confetes
            const container = document.getElementById('confettiContainer');
            const colors = ['#EC4899', '#F59E0B', '#10B981', '#3B82F6', '#8B5CF6'];
            for (let i = 0; i < 40; i++) {
                const p = document.createElement('div');
                p.className = 'confetti-piece';
                p.style.left = Math.random() * 100 + '%';
                p.style.background = colors[Math.floor(Math.random() * colors.length)];
                p.style.width = (Math.random() * 8 + 5) + 'px';
                p.style.height = (Math.random() * 8 + 5) + 'px';
                p.style.animationDuration = (Math.random() * 3 + 2) + 's';
                container.appendChild(p);
            }
        }, 1000);
    }

    // --- LГ“GICA DO CHAT ---
    const chatState = { 
        isOpen: false, 
        activeUserId: null, 
        pollingInterval: null, 
        lastTotalUnread: 0,
        lastMsgCount: 0 
    };

    // ENGINE DE ГҒUDIO ROBUSTA (Web Audio API)
    let audioCtx = null;
    
    function initAudio() {
        if (!audioCtx) {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            console.log('Chat: AudioContext Inicializado');
        }
        if (audioCtx.state === 'suspended') audioCtx.resume();
    }

    function playBeep(type) {
        initAudio();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);

        if (type === 'sent') {
            osc.type = 'sine';
            osc.frequency.setValueAtTime(880, audioCtx.currentTime);
            gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
            osc.start(audioCtx.currentTime);
            osc.stop(audioCtx.currentTime + 0.1);
        } else {
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(523.25, audioCtx.currentTime);
            osc.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.1);
            gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
            osc.start(audioCtx.currentTime);
            osc.stop(audioCtx.currentTime + 0.3);
        }
    }

    function playAudio(type) {
        if (!audioCtx || audioCtx.state !== 'running') {
            console.log('Chat: AudioContext ainda nГЈo estГЎ ativo (esperando clique)');
            return;
        }
        playBeep(type);
    }
    
    // Destravar AudioContext no primeiro clique
    document.addEventListener('click', initAudio, { once: true });

    window.toggleChatPanel = function() {
        const panel = document.getElementById('chatPanel');
        chatState.isOpen = !chatState.isOpen;
        panel.style.display = chatState.isOpen ? 'flex' : 'none';
        
        // Se fechar o chat, remove o "minimizado" para que abra normal da prГіxima vez
        if (!chatState.isOpen) {
            panel.classList.remove('chat-minimized');
        }

        if (chatState.isOpen) { loadUserList(); startPolling(); } else { stopPolling(); }
    };

    window.toggleChatMinimize = function(e) {
        if (e) e.stopPropagation();
        const panel = document.getElementById('chatPanel');
        panel.classList.toggle('chat-minimized');
    };

    window.filterChatUsers = function() {
        const input = document.getElementById('chatUserSearch');
        if(!input) return;
        const filter = input.value.toLowerCase();
        const items = document.querySelectorAll('.chat-user-item');
        items.forEach(item => {
            const nameEl = item.querySelector('div[style*="font-weight:700"]');
            if(nameEl) {
                const name = nameEl.innerText.toLowerCase();
                item.style.display = name.includes(filter) ? 'flex' : 'none';
            }
        });
    };

    window.backToUserList = function() {
        document.getElementById('chatSearchArea').style.display = 'block';
        document.getElementById('chatUserList').style.display = 'block';
        document.getElementById('chatActiveWindow').style.display = 'none';
        chatState.activeUserId = null;
        chatState.lastMsgCount = 0;
        loadUserList();
    };

    async function loadUserList() {
        try {
            const resp = await fetch('chat_api.php?action=list_users');
            const users = await resp.json();
            const listContainer = document.getElementById('chatUserList');
            let html = '';
            let totalUnread = 0;

            users.forEach(u => {
                totalUnread += parseInt(u.unread_count);
                const avatar = u.avatar_url ? `<img src="${u.avatar_url}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">` : u.name.substring(0,2).toUpperCase();
                const nameColor = u.is_online ? '#10b981' : '#ef4444';
                
                html += `
                    <div class="chat-user-item" onclick="openChatWith('${u.id}', '${u.name}', '${u.avatar_url || ''}')">
                        <div class="chat-user-avatar">${avatar}<div class="status-dot ${u.is_online ? 'status-online' : 'status-offline'}"></div></div>
                        <div style="flex:1">
                            <div style="font-weight:700; font-size:0.85rem; color:${nameColor}">${u.name}</div>
                            <div style="font-size:0.7rem; color:#64748b;">${u.is_online ? 'Online' : 'Offline'}</div>
                        </div>
                        ${u.unread_count > 0 ? `<span class="badge-danger" style="padding:2px 6px; font-size:0.6rem; border-radius:10px;">${u.unread_count}</span>` : ''}
                    </div>
                `;
            });
            listContainer.innerHTML = html || '<div style="text-align:center;padding:2rem;color:#64748b;font-size:0.8rem;">Nenhum usuГЎrio encontrado.</div>';
            updateGlobalBadge(totalUnread);
            if (typeof filterChatUsers === 'function') filterChatUsers();
        } catch (e) {}
    }

    function updateGlobalBadge(count) {
        const badge = document.getElementById('globalChatBadge');
        const btn = document.getElementById('chatMainBtn');
        
        // Tocar som se a contagem aumentar (recebeu nova)
        if (count > chatState.lastTotalUnread) {
            playAudio('received');
        }
        chatState.lastTotalUnread = count;

        if (count > 0) { badge.innerText = count; badge.style.display = 'flex'; btn.classList.add('chat-pulse'); }
        else { badge.style.display = 'none'; btn.classList.remove('chat-pulse'); }
    }

    window.openChatWith = async function(userId, name, avatar) {
        if (chatState.activeUserId !== userId) {
            chatState.lastMsgCount = 0;
        }
        chatState.activeUserId = userId;
        document.getElementById('chatSearchArea').style.display = 'none';
        document.getElementById('chatUserList').style.display = 'none';
        const win = document.getElementById('chatActiveWindow');
        win.style.display = 'flex';
        win.style.flexDirection = 'column'; 
        
        document.getElementById('activeUserName').innerText = name;
        const avatarDiv = document.getElementById('activeUserAvatar');
        avatarDiv.innerHTML = avatar ? `<img src="${avatar}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">` : name.substring(0,2).toUpperCase();
        await fetch(`chat_api.php?action=mark_as_read&other_id=${userId}`);
        loadMessages();
        document.getElementById('chatInput').focus();
    };

    async function loadMessages() {
        if (!chatState.activeUserId) return;
        try {
            const resp = await fetch(`chat_api.php?action=get_messages&other_id=${chatState.activeUserId}`);
            const msgs = await resp.json();
            
            // LГіgica de Som Interno (Nova mensagem enquanto janela aberta)
            if (msgs.length > chatState.lastMsgCount) {
                const lastMsg = msgs[msgs.length - 1];
                // SГі toca se NГғO for minha mensagem E a janela estiver focada
                if (lastMsg.sender_id === chatState.activeUserId && chatState.lastMsgCount > 0) {
                    playAudio('received');
                }
            }
            chatState.lastMsgCount = msgs.length;

            const msgContainer = document.getElementById('chatMessages');
            let html = '';
            msgs.forEach(m => {
                const isSent = m.sender_id === '<?= $user['id'] ?>';
                const readStatus = (isSent && m.is_read == 1) ? `<div style="font-size:0.55rem; color:rgba(255,255,255,0.7); margin-top:2px;">вң“ Lido em: ${m.read_formatted}</div>` : '';
                
                let contentHtml = m.content;
                if (m.type === 'audio') {
                    contentHtml = `<audio src="uploads/chat_files/${m.content}" controls style="max-width:200px; height:30px;"></audio>`;
                } else if (m.type === 'image') {
                    contentHtml = `<img src="uploads/chat_files/${m.content}" style="max-width:100%; border-radius:10px; cursor:pointer" onclick="window.open(this.src)">`;
                } else if (m.type === 'file') {
                    contentHtml = `<a href="uploads/chat_files/${m.content}" target="_blank" style="color:inherit; text-decoration:none; display:flex; align-items:center; gap:8px;">
                        <i class="fa-solid fa-file-lines" style="font-size:1.5rem"></i>
                        <span style="font-size:0.8rem; text-decoration:underline">Ver Arquivo</span>
                    </a>`;
                }

                html += `
                    <div class="msg ${isSent ? 'msg-sent' : 'msg-received'}">
                        ${contentHtml}
                        <div style="display:flex; justify-content:space-between; align-items:center; gap:10px;">
                            ${isSent ? readStatus : ''}
                            <span class="msg-time">${m.time_formatted}</span>
                        </div>
                    </div>
                `;
            });
            const shouldScroll = msgContainer.scrollTop + msgContainer.clientHeight >= msgContainer.scrollHeight - 50;
            msgContainer.innerHTML = html;
            if (shouldScroll) msgContainer.scrollTop = msgContainer.scrollHeight;
            
            // Auto marcar como lido se a janela estiver aberta
            if (msgs.some(m => m.sender_id === chatState.activeUserId && m.is_read == 0)) {
                fetch(`chat_api.php?action=mark_as_read&other_id=${chatState.activeUserId}`);
            }
        } catch (e) {}
    }

    window.sendMessage = async function() {
        const input = document.getElementById('chatInput');
        const content = input.value.trim();
        if (!content || !chatState.activeUserId) return;
        const formData = new FormData();
        formData.append('receiver_id', chatState.activeUserId);
        formData.append('content', content);
        formData.append('type', 'text');
        input.value = '';
        try { 
            await fetch('chat_api.php?action=send', { method: 'POST', body: formData }); 
            playAudio('sent');
            loadMessages(); 
        } catch (e) {}
    };

    // --- LIMPAR CHAT ---
    window.clearChat = async function() {
        if (!chatState.activeUserId) return;
        if (!confirm('Deseja limpar as mensagens desta conversa apenas para vocГӘ?')) return;
        const formData = new FormData();
        formData.append('other_id', chatState.activeUserId);
        try {
            await fetch('chat_api.php?action=clear_chat', { method: 'POST', body: formData });
            loadMessages();
        } catch(e) {}
    };

    // --- ENVIO DE ARQUIVOS ---
    window.openFileSelector = function() {
        document.getElementById('chatFileInput').click();
    };

    window.uploadChatFile = async function(input) {
        if (!input.files || !input.files[0] || !chatState.activeUserId) return;
        const file = input.files[0];
        const formData = new FormData();
        formData.append('file', file);
        formData.append('receiver_id', chatState.activeUserId);
        
        try {
            await fetch('chat_api.php?action=upload_file', { method: 'POST', body: formData });
            playAudio('sent');
            loadMessages();
            input.value = ''; // Limpar seletor
        } catch (e) {
            alert('Erro ao enviar arquivo.');
        }
    };

    // --- LГ“GICA DO PEIXINHO IA ---
    window.openPeixinhoChat = function() {
        if (!chatState.isOpen) toggleChatPanel();
        openChatWith('U_PEIXINHO', 'Peixinho (IA)', 'assets/img/peixinho.png');
    };

    // --- SELETOR DE EMOJIS (IMPLEMENTAГҮГғO COMPLETA) ---
