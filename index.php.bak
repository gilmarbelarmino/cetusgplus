<?php
// ======================== MODAL DE ANIVERSГҒRIO ========================
$birthdayPeople = [];
try {
    $bdStmt = $pdo->query("
        SELECT u.id, u.name, u.avatar_url, rh.birth_date 
        FROM users u 
        JOIN rh_employee_details rh ON BINARY u.id = BINARY rh.user_id 
        WHERE MONTH(rh.birth_date) = MONTH(CURDATE()) 
        AND DAY(rh.birth_date) = DAY(CURDATE())
        AND u.status = 'Ativo'
    ");
    $birthdayPeople = $bdStmt->fetchAll(PDO::FETCH_ASSOC);
} catch(Exception $e) {}

// ======================== MODAL DE RECADOS GERAL ========================
$unreadAnnouncement = null;
if (isset($pdo)) {
    try {
        // Pega o recado mais recente
        $annStmt = $pdo->query("SELECT * FROM announcements ORDER BY created_at DESC LIMIT 1");
        $latestAnn = $annStmt->fetch(PDO::FETCH_ASSOC);
        
        if ($latestAnn) {
            $sessionKey = 'announcement_shown_' . $latestAnn['id'];
            if (!isset($_SESSION[$sessionKey])) {
                $unreadAnnouncement = $latestAnn;
            }
        }
    } catch(Exception $e) {}
}
?>

