<script>
function closeAnnouncementModal(id) {
    const modal = document.getElementById('announcementModal');
    
    // Inicia fechamento visual
    modal.style.transition = 'opacity 0.3s ease, visibility 0.3s ease';
    modal.style.opacity = '0';
    modal.style.visibility = 'hidden';
    
    // Remove do layout logo apГіs o efeito visual
    setTimeout(() => {
        modal.style.display = 'none';
        modal.remove(); // Remove o elemento para garantir que nГЈo bloqueie nada
    }, 350);
    
    // Notifica backend em background (nГЈo aguarda resposta para fechar)
    fetch('announcements_api.php?action=mark_as_read&id=' + id).catch(e => console.error(e));
}
</script>
